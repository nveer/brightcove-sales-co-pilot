# ============================================================
# SE Command Center — Environment Configuration
# ============================================================
# SETUP: Copy this file to scripts/.env and fill in YOUR credentials.
#        cp scripts/.env.example scripts/.env
#
# Never commit scripts/.env — it contains your personal credentials.
#
# Need API access?
#   Gong:        Submit an IT ticket asking for Gong API credentials
#   Salesforce:  Submit an IT ticket asking for a Salesforce Connected App
#                with OAuth 2.0 password flow enabled
# ============================================================

# --- Gong API ---
# Obtain from your Gong admin (Gong Admin > Settings > API)
GONG_ACCESS_KEY=your_gong_access_key_here
GONG_ACCESS_KEY_SECRET=your_gong_access_secret_here
# Your org-specific base URL — looks like https://us-XXXXX.api.gong.io/v2
GONG_BASE_URL=https://us-XXXXX.api.gong.io/v2

# --- Salesforce ---
# SF_CONSUMER_KEY and SF_CONSUMER_SECRET come from a Connected App (IT creates this)
# SF_USERNAME, SF_PASSWORD, SF_SECURITY_TOKEN are your own Salesforce credentials
SF_CONSUMER_KEY=your_consumer_key
SF_CONSUMER_SECRET=your_consumer_secret
SF_USERNAME=your.email@brightcove.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_security_token
SF_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
